# .env.example — шаблон переменных окружения
# Скопируйте в .env и заполните реальными значениями!

# ================== БАЗА ДАННЫХ ==================
DATABASE_URL=postgresql://instacapture:changeme_strong_password@db:5432/instacapture

# ================== TELEGRAM ==================
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ADMIN_CHAT_ID=your_telegram_chat_id

# ================== ШИФРОВАНИЕ ==================
# Сгенерируйте ключ командой:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SERVER_ENCRYPTION_KEY=your_fernet_key_here

# ================== API ==================
# Ключ для авторизации Android-приложения (любая длинная случайная строка)
API_KEY=your_random_api_key_min_32_chars
